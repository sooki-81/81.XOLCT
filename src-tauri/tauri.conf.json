{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "XOLCT",
  "version": "1.1.5",
  "identifier": "com.xolct.wallpaper",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "81.ХОЛСТ",
        "width": 1920,
        "height": 1080,
        "x": 0,
        "y": 0,
        "decorations": false,
        "transparent": false,
        "resizable": false,
        "skipTaskbar": true,
        "shadow": false,
        "visible": false
      },
      {
        "label": "welcome",
        "url": "welcome.html",
        "title": "81.ХОЛСТ",
        "width": 1130,
        "height": 750,
        "center": true,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "skipTaskbar": false,
        "visible": false,
        "shadow": false
      }
    ],
